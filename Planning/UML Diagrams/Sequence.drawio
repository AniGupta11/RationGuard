        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle RationGuard AI - Sequence Diagram\n\nactor Customer\nparticipant \&quot;Face Recognition\&quot; as FR\nparticipant \&quot;System\&quot; as SYS\nparticipant \&quot;Database\&quot; as DB\nparticipant \&quot;Fraud Detection\&quot; as FD\nparticipant \&quot;PDF Generator\&quot; as PDF\nparticipant \&quot;WhatsApp Service\&quot; as WA\n\nCustomer -&gt; FR: Login (Face)\nFR -&gt; DB: Verify Face Embedding\nDB --&gt; FR: Match Result\nFR -&gt; SYS: Login Success/Failure\n\nalt Face Fail\n  Customer -&gt; SYS: Aadhaar + Ration_ID\n  SYS -&gt; DB: Verify Credentials\n  DB --&gt; SYS: Result\nend\n\nCustomer -&gt; SYS: Enter Ration Request\nSYS -&gt; FD: Run Fraud Checks\nFD --&gt; SYS: Fraud / Genuine\n\nalt Fraud\n  SYS -&gt; DB: Log Fraud Attempt\n  SYS -&gt; Customer: Deny Transaction\nelse Genuine\n  SYS -&gt; DB: Save Transaction\n  SYS -&gt; PDF: Generate Bill\n  PDF --&gt; Customer: Download Bill\n  SYS -&gt; WA: Send Alert (if ≤30% ration left)\nend\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="fjxyf2C9GJ2lVJN7pg6x-3">
